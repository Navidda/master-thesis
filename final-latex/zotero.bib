@incollection{curry_organizational_2022,
	location = {Cham},
	title = {An Organizational Maturity Model {forData} Spaces: A Data Sharing Wheel Approach},
	isbn = {978-3-030-98636-0},
	url = {https://doi.org/10.1007/978-3-030-98636-0_2},
	shorttitle = {An Organizational Maturity Model {forData} Spaces},
	abstract = {This chapter presents a maturity model for Data Spaces, which provides a management system with associated improvement roadmaps that guide strategies to continuously improve, develop, and manage the data space capability within their organization. It highlights the challenges with data sharing and motivates the benefit of maturity models. This chapter describes the Maturity Model for Data Spaces ({MM}4DS) and its use to determine an organization’s data space capability maturity. The {MM}4DS takes an organization’s user-centric/demand-side perspective utilizing a data space. The development process for the {MM}4DS is discussed, along with the role of design science in the model development process. Finally, the chapter details an illustrative case using the model to benchmark data space capabilities in five fictitious organizations. The {MM}4DS can be applied within organizations to better manage their data space capabilities, with assessment, providing insights into what they are doing well and where they need to improve.},
	pages = {21--42},
	booktitle = {Data Spaces : Design, Deployment and Future Directions},
	publisher = {Springer International Publishing},
	author = {Curry, Edward and Tuikka, Tuomo},
	editor = {Curry, Edward and Scerri, Simon and Tuikka, Tuomo},
	urldate = {2023-10-29},
	date = {2022},
	langid = {english},
	doi = {10.1007/978-3-030-98636-0_2},
	keywords = {Big Data value, Data ecosystem, Data innovation, Data space, Maturity model},
}

@incollection{gabrielli_kraken_2022,
	location = {Cham},
	title = {{KRAKEN}: A Secure, Trusted, Regulatory-Compliant, and Privacy-Preserving Data Sharing Platform},
	isbn = {978-3-030-98636-0},
	url = {https://doi.org/10.1007/978-3-030-98636-0_6},
	shorttitle = {{KRAKEN}},
	abstract = {The {KRAKEN} project aims to enable the sharing, brokerage, and trading of personal data including sensitive data (e.g., educational and health records and wellbeing data from wearable devices) by returning its control to both data subjects/data providers throughout the entire data lifecycle. The project is providing a data marketplace which will allow the sharing of personal data and its usage for research and business purposes, by using privacy-preserving cryptographic tools. {KRAKEN} is developing an advanced platform to share certified information between users and organizations by leveraging on distributed ledger technology, promoting the vision of self-sovereign identity solutions (ensuring users’ consent and data control in a privacy-friendly way), preserving security, privacy, and the protection of personal data in compliance with {EU} regulations (e.g., {GDPR}). The feasibility of the {KRAKEN} solution will be tested through two high-impact pilots in the education and healthcare fields.},
	pages = {107--130},
	booktitle = {Data Spaces : Design, Deployment and Future Directions},
	publisher = {Springer International Publishing},
	author = {Gabrielli, Silvia and Krenn, Stephan and Pellegrino, Donato and Pérez Baún, Juan Carlos and Pérez Berganza, Pilar and Ramacher, Sebastian and Vandevelde, Wim},
	editor = {Curry, Edward and Scerri, Simon and Tuikka, Tuomo},
	urldate = {2023-10-29},
