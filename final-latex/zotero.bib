	keywords = {Communication networks, Critical Cyber-Physical Systems, Dataspaces, {NFV}, Power system dynamics, Redundancy, Resilience, {SDN}, Smart Grid, Smart grids, Stability analysis, Stakeholders, Telecommunications},
}

