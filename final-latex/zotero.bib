}

@inproceedings{sayad_towards_2023,
	title = {Towards Cross-domain Resilience in {SDN}-enabled Smart Power Grids: Enabling Information Sharing through Dataspaces},
	url = {https://ieeexplore.ieee.org/abstract/document/10189319/references#references},
	doi = {10.1109/COINS57856.2023.10189319},
	shorttitle = {Towards Cross-domain Resilience in {SDN}-enabled Smart Power Grids},
	abstract = {In this paper, we present a use case of cross-domain resilience based on coordinated resource orchestration in a network of Edge Data-Centers ({EDCs}). Cross-domain resilience is achieved through data exchanges based on the International Data Space Association ({IDSA}) architecture, and the Edge Data-Centers are assumed to host critical applications for monitoring and control of both the telecommunications and power networks. In the context of Software-Defined Networking ({SDN})-enabled smart power grid, Energy Management Systems ({EMSs}) are deployed as distributed applications that rely on communication network programmability to achieve the quality-of service-objectives. The communication network programmability is performed as-a-service, by distributed {SDN}-Controllers ({SDN}-C) operated by the telecommunication operator. To ensure the high availability of these critical functions, we propose an {IDSA}-based centralized resilience orchestrator framework that ensures a dynamic service redundancy scheme to achieve failure tolerance and high availability of critical services in the {SDN}-enabled smart power grid.},
	eventtitle = {2023 {IEEE} International Conference on Omni-layer Intelligent Systems ({COINS})},
	pages = {1--6},
