@article{brumm_data_nodate,
	title = {On Data Sovereignty in business: A showcase of the concept of Data Sovereignty and implementing architectures},
	abstract = {The world of Big Data offers new ways to generate value to companies, but also confronts companies and customers with challenges in retaining control over their data. My goal in this study is to showcase what Data Sovereignty means in regard to these problems, what issues and opportunities it entails. To achieve this, the general notion of Data Sovereignty is showcased and broken down into examples, possible opportunities and conflicts found by various research are also presented. Five solutions, each of them aiming to achieve Data Sovereignty in different contexts, are presented and discussed regarding their stated goals, effectiveness and existing implementations.},
	author = {Brumm, Christian},
	langid = {english},
}

